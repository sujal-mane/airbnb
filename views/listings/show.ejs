<% layout('/layouts/boilerplate.ejs') -%>
<script> 
    const MapToken="<%= process.env.MAP_TOKEN %>";
    const coordinates= "<%- JSON.stringify(listing.geometry.coordinates) %>" ;
</script>
<div class="row mt-4 mb-4">
    <div class="col-lg-8 offset-2 mt-3">
        <h3>Listing details :</h3>
        <div class="card col-6 offset-2 show-card listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-img">
            <div class="card-body">
                <p class="card-text"> 
                    <b><%= listing.title %></b> <br></p>
                    <% if(listing.owner) { %><i> by <%= listing.owner.username %> </i><% } %><br> 
                    <%= listing.description %> <br>

                   <% if (typeof listing.price === "number") { %>
              &#8377;<%= listing.price.toLocaleString("en-IN") %> <small>/ night</small>
            <% } else { %>
              Price on request
            <% } %>
                    <%= listing.location %> <br>
                    <%= listing.country %>
                
            </div>
        </div>


<div class="col-1 btn">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark offset-2 edit-btn">Edit</a>
            <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
                <button class="btn btn-dark"> DELETE</button>
            </form>
        </div>
    
        
    </div>
     <%  if(currUser) { %>
    <div class="col-lg-8 offset-2">
        <hr>
        <h5> Leave YOUR Review</h5>
        <form method="Post" action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation">
           <div class="col-lg-8 offset-2">
             <label for="rating" class="form-label"> Rating </label>
<fieldset class="starability-slot">
   
    <!-- <input type="range" id="rating" name="review[rating]" min="1" max="5" class="form-range"> -->

  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div> 
            <div class="mb-3" mt="3">
                <label for="comment" class="form-label"> Comment </label>
                <textarea name="review[comment]" id="comment" rows="3" cols="10" class="form-control" required></textarea>
                <div class="inavalid-feedback">Please add  som comment for review </div>
            </div>
 <button class="mb-3" mt="3"> Sumbit </button>
        </form>
        <% } %>
<hr>
<% if(listing.reviews.length > 0) { %>
 <h4> All Reviews </h4>
 
        <% for(review of listing.reviews){ %>
            <div class="card mb-3 mt-3">
                 <div class="card-body">
                    
                     <h5 class="card-title"> <% if(review.author) { %> <%= review.author.username %> <% } %> </h5>
                     <p class="card-text"> <%= review.comment %> </p>
                    
                       <p class="starability-result  card-text" data-rating="<%= review.rating %>"> </p>
  
  
                 </div>
                <form class="mb-3"  method ="Post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                    <button class="btn btn-dark btn-sm " >  DELET </button>

                     </form>
            </div>
   <% }%>
<% } %>
    </div>

    <div class="col-lg-8 offset-2">
        <h3> Where you will be</h3>
        <div id="map"></div>

    </div>
</div>
<script src="/js/map.js"></script>
